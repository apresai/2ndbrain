.env
.env.*
# Local code-signing / notarization config (identity + notary key path/IDs).
# Real values live here on the maintainer's machine only; the committed
# scripts/sign.env.example is the template. Keys themselves stay in ~/dev/certs.
scripts/sign.env
node_modules/
.DS_Store

# Claude Code
.claude/

# Go
cli/bin/
*.exe
dist/
# Packaged macOS app artifacts (built by package-app / notarize-app at repo root).
SecondBrain-*-arm64.zip
*.dmg

# Swift / Xcode
app/DerivedData/
app/*.xcodeproj/xcuserdata/
app/*.xcworkspace/xcuserdata/
.build/
.swiftpm/

# Vault content — never commit personal knowledge base data.
# Anchored to repo root so it doesn't collide with the Go package
# at cli/internal/vault or the Swift module at
# app/Sources/SecondBrainCore/Vault (both tracked).
/vault/
# .2ndbrain/ holds the SQLite index.db, bench.db, models/, recovery/, logs/ —
# machine-local derived state, never commit. (git has no trailing-inline-comment
# support, so this comment must sit on its own line above the bare pattern.)
.2ndbrain/
