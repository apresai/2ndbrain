# obsidian declares @codemirror/* as peerDependencies that the Obsidian app
# provides at runtime (they are marked `external` in esbuild.config.mjs), and
# vitest@4 lists @types/node (>=24) as an optional peer (satisfied by our
# @types/node@24). legacy-peer-deps keeps `npm install`/`npm ci` from pulling
# those app-provided peers into the tree or erroring on the benign optional-peer
# graph. @types/node is compile-time only (type-checking); vitest transpiles
# tests via esbuild without type-checking.
legacy-peer-deps=true
