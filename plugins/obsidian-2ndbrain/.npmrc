# vitest@4 lists @types/node (>=24) as an optional peer; this plugin pins
# @types/node@18 for the production build. @types/node is compile-time only and
# vitest transpiles tests via esbuild without typechecking, so the mismatch is
# benign. legacy-peer-deps lets `npm install` proceed without forcing a
# @types/node bump that could break the TypeScript 4.9 production build.
legacy-peer-deps=true
