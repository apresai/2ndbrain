# Local code-signing + notarization config for `make notarize-app` / `make release-app`.
#
# Copy to scripts/sign.env (gitignored) and fill in your values. Everything here
# stays on your machine — the private signing key and notary key are referenced
# by path and never copied into the repo. Code signing is asymmetric, so the
# shipped app embeds only your PUBLIC certificate; the private key never leaves
# your keychain / cert store.

# Developer ID Application identity used by `codesign --sign`. Use the name or
# the SHA-1, exactly as printed by:  security find-identity -v -p codesigning
SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# App Store Connect API key for `xcrun notarytool` (the .p8 stays in your cert
# store; only its path is referenced here).
ASC_KEY_PATH="$HOME/dev/certs/api-keys/AuthKey_XXXXXXXXXX.p8"
ASC_KEY_ID="XXXXXXXXXX"
ASC_ISSUER_ID="00000000-0000-0000-0000-000000000000"
